{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- printf "<?xslt-param name=\"permalink\" value=\"%s\"?>" ( .Permalink | replaceRE ":" "%3A" ) | safeHTML }}
{{- printf "<?xml-stylesheet href=\"/rss.xsl\" type=\"text/xsl\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>RRRA News</title>
    <link>{{ .Permalink -}}</link>
    <description>{{ site.Title -}}</description>
    <generator>hugo.Generator</generator>
    {{ with site.LanguageCode -}}<language>{{ . -}}</language>{{ end -}}
    {{ with site.Author.email -}}<managingEditor>{{ . -}}{{ with site.Author.name -}} ({{ . -}}){{ end -}}</managingEditor>{{ end -}}
    {{ with site.Author.email -}}<webMaster>{{ . -}}{{ with site.Author.name -}} ({{ . -}}){{ end -}}</webMaster>{{ end -}}
    {{ with site.Copyright -}}<copyright>{{ . -}}</copyright>{{ end -}}
    {{ if not .Date.IsZero -}}<lastBuildDate>{{ now | dateFormat "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML -}}</lastBuildDate>{{ end -}}
    <atom:link href="{{ site.BaseURL }}index.xml" rel="self" type="application/rss+xml"/>
    <item>
      <title>Upcoming Events RSS Feed</title>
      <link>{{ if ne "development" hugo.Environment }}{{ site.BaseURL -}}{{ else -}}/{{ end -}}calendar/index.xml</link>
      <pubDate>{{ now | dateFormat "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML -}}</pubDate>
      {{ with site.Author.email -}}<author>{{ . -}}{{ with site.Author.name }} ({{ . -}}){{ end -}}</author>{{ end -}}
      <guid>https://rrra.org/calendar/index.xml</guid>
      <description>Subscribe to RRRA's Upcoming Events RSS Feed to keep track of the current upcoming events on our club calendar.</description>
    </item>
    {{ range first 15 (where site.Pages.ByDate "Section" "post").Reverse -}}
      {{ if ne "Posts" .Title -}}
	<item>
	  <title>{{ replace ( .Title | markdownify | htmlUnescape | plainify ) "&" " and " -}}{{ with replace ( .Params.subTitle | markdownify | plainify ) "&" " and " }} - {{ . }}{{ end }}</title>
	  <link>{{ .Permalink -}}</link>
	  <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML -}}</pubDate>
	  {{ with site.Author.email -}}<author>{{ . -}}{{ with site.Author.name }} ({{ . -}}){{ end -}}</author>{{ end -}}
	  <guid>{{ .Permalink -}}</guid>
	  <description>{{ replace ( .Summary | htmlUnescape | plainify ) "&" " and " }}</description>
	</item>
      {{ end -}}
    {{ end -}}
  </channel>
</rss>

